{
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Debug" ],
        "WriteTo": [
            {
                "Name": "Console"
            }
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "System": "Information",
                "Microsoft": "Information",
                "System.Net.Http.HttpClient": "Warning"
            }
        }
    },
    "Headless": {
        "resonitePath": "/opt/Resonite",
	"invisible": "true",
    },
    "Resonite": {
        "dataFolder": "/var/lib/resonite/data",
        "cacheFolder": "/var/lib/resonite/cache",
        "logsFolder": "/var/lib/resonite/logs"
    }
}
